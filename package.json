{
  "name": "superplane-hackaton",
  "version": "1.0.0",
  "description": "Superplane challenge",
  "main": "index.js",
  "scripts": {
    "dev:agent": "nodemon --exec ts-node src/agent/server.ts",
    "dev:webhook": "nodemon --exec ts-node src/webhook-server.ts",
    "dev:mock": "nodemon --exec ts-node src/mock/broken-service.ts",
    "dev:dashboard": "nodemon --exec ts-node src/dashboard/server.ts",
    "dev:demo": "nodemon --exec ts-node src/demo-app/app.ts",
    "dev:all": "concurrently -n agent,webhook,mock,dashboard -c blue,green,red,cyan \"npm run dev:agent\" \"npm run dev:webhook\" \"npm run dev:mock\" \"npm run dev:dashboard\"",
    "dev:full": "concurrently -n agent,webhook,mock,dashboard,demo -c blue,green,red,cyan,magenta \"npm run dev:agent\" \"npm run dev:webhook\" \"npm run dev:mock\" \"npm run dev:dashboard\" \"npm run dev:demo\"",
    "build": "tsc",
    "start": "node dist/dashboard/server.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pappt04/Superplane-hackaton.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Pappt04/Superplane-hackaton/issues"
  },
  "homepage": "https://github.com/Pappt04/Superplane-hackaton#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "groq-sdk": "^1.1.2",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2"
  }
}
