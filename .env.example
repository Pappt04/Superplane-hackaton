GEMINI_API_KEY=your-gemini-api-key-here
ANTHROPIC_API_KEY=sk-ant-...
PORT=3001

# Webhook Server (Person 1)
WEBHOOK_PORT=3000
WEBHOOK_SERVER_URL=http://localhost:3000

# Mock Service (Person 1)
MOCK_PORT=3002

# Dashboard (Person 1)
DASHBOARD_PORT=3003
DASHBOARD_URL=http://localhost:3003

# Agent URL (used by webhook-server to call the agent)
AGENT_URL=http://localhost:3001

# Discord (used by SuperPlane for incident notifications)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# SuperPlane webhook trigger URLs (fill in after creating canvases in SuperPlane UI)
SUPERPLANE_TRIAGE_WEBHOOK_URL=
SUPERPLANE_ESCALATION_WEBHOOK_URL=

# GitHub (deployments + code diff)
GITHUB_TOKEN=ghp_...
GITHUB_ORG=your-org-name

# AWS (infrastructure health check)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# Prometheus / Grafana (DB statistics)
PROMETHEUS_URL=http://prometheus:9090
PROMETHEUS_TOKEN=prom_...
GRAFANA_URL=http://grafana:3000
GRAFANA_API_KEY=glsa_...

GROQ_API_KEY=your-groq-key
